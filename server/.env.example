# user host.docker.internal instead of localhost for database connection when running in Docker container
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/sebotics"

PORT=8080

JWT_SECRET="replace-with-a-long-random-string"
JWT_EXPIRES_IN="12h"

REFRESH_TOKEN_SECRET="replace-with-another-long-random-string"
REFRESH_TOKEN_EXPIRES_IN="7d"

AUTOXING_BASE_URL="https://api.autoxing.com"
AUTOXING_APP_ID="your-app-id"
AUTOXING_APP_SECRET="your-app-secret"
AUTOXING_APP_CODE="your-app-code"
AUTOXING_TIMESTAMP_UNIT="ms"
