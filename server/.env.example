# Host runtime (npm run dev / prisma from your machine)
DATABASE_URL="postgresql://sebotics_app:sebotics_app@127.0.0.1:5432/sebotics?schema=public"

# Optional override for docker compose container runtime.
# Leave empty to use the internal postgres service from docker-compose.yml.
DATABASE_URL_CONTAINER=""

POSTGRES_DB="sebotics"
POSTGRES_USER="sebotics_app"
POSTGRES_PASSWORD="sebotics_app"

PORT=8080
CORS_ORIGIN="http://localhost:5173"
ENABLE_SWAGGER="true"

MAPBOX_TOKEN=pk.your_token_here

# Rate limiting (requests per window)
# short: per 1s, medium: per 10s, long: per 60s
THROTTLE_SHORT_TTL_MS=1000
THROTTLE_SHORT_LIMIT=10
THROTTLE_MEDIUM_TTL_MS=10000
THROTTLE_MEDIUM_LIMIT=60
THROTTLE_LONG_TTL_MS=60000
THROTTLE_LONG_LIMIT=240

JWT_SECRET="replace-with-a-long-random-string"
JWT_EXPIRES_IN="12h"

REFRESH_TOKEN_SECRET="replace-with-another-long-random-string"
REFRESH_TOKEN_EXPIRES_IN="7d"

AUTOXING_BASE_URL="https://apiglobal.autoxing.com"
AUTOXING_WS_BASE_URL="wss://serviceglobal.autoxing.com"
AUTOXING_APP_ID="app-id"
AUTOXING_APP_SECRET="app-secret"
AUTOXING_APP_CODE="app-code"
AUTOXING_TIMESTAMP_UNIT="ms"

# Elevator emulation (dumb-elevator system)
ELEVATOR_WS_BASE_URL="http://localhost:8080"

# Mail sender information
MAIL_FROM_NAME="Sebotics"
MAIL_FROM_ADDRESS="noreply@sebotics.com"

# SMTP Configuration
# When MAIL_SMTP_HOST is set, emails are sent via SMTP.
# When it is left empty, emails are printed to the console (dev/test mode).
MAIL_SMTP_HOST=
MAIL_SMTP_PORT=465
MAIL_SMTP_SECURE="true"
MAIL_SMTP_USER=
MAIL_SMTP_PASS=
