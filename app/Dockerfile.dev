FROM node:22-alpine

WORKDIR /app

ENV PATH /app/node_modules/.bin:$PATH

# Install dependencies (cached). package-lock.json optional.
COPY package*.json ./
RUN npm install --silent

# Expose Vite dev server
EXPOSE 5173

# Start Vite dev server, bind to all interfaces so host can reach it
CMD ["npm","run","dev","--","--host","0.0.0.0"]
